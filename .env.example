# AlphaFin 한국판 API 키 설정
# cp .env.example .env 후 실제 값 입력
# ⚠️  .env.example에는 실제 키를 절대 입력하지 마세요 (git에 커밋됩니다)

# ── Claude (학교 제공) ──────────────────────────────────────────
ANTHROPIC_API_KEY=your_anthropic_key   # 학교 제공 API 키 입력

# ── OpenAI (합성기 + 임베딩 전용, 프로젝트 전체 ~$0.05) ─────────
OPENAI_API_KEY=your_openai_key         # platform.openai.com → 신규 $5 크레딧

# ── 데이터 수집 (모두 무료) ─────────────────────────────────────
DART_API_KEY=your_dart_key             # opendart.fss.or.kr
NAVER_CLIENT_ID=your_naver_id          # developers.naver.com
NAVER_CLIENT_SECRET=your_naver_secret

# ── Telegram 알림 (n8n 워크플로우용, 선택) ───────────────────────
# @BotFather 에서 봇 생성 → 토큰 발급
# 채팅 시작 후 https://api.telegram.org/bot{TOKEN}/getUpdates 로 chat_id 확인
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_CHAT_ID=your_telegram_chat_id
